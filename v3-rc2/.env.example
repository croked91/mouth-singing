# === Required API keys ===
MVSEP_API_KEY=your_mvsep_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GENIUS_TOKEN=your_genius_token_here

# === Optional overrides ===
# ADMIN_SECRET=changeme
# LOG_LEVEL=INFO
# APP_PORT=80
# WORKER_POLL_INTERVAL=2

# === Embedder backend ===
# "local" = sentence-transformers (default, no extra API cost)
# "openai" = text-embedding-3-small (requires reindexing existing vectors)
# LYRIC_EMBEDDER_BACKEND=local

# === Feature normalization ===
# NORMALIZATION_STATS_PATH=/data/models/feature_normalization_stats.json

# === MVSEP overrides (rarely needed) ===
# MVSEP_SEP_TYPE=49
# MVSEP_POLL_INTERVAL_SEC=10
# MVSEP_TIMEOUT_SEC=600

# === Whisper overrides ===
# WHISPER_MODEL=whisper-1
# WHISPER_TIMEOUT_SEC=120
