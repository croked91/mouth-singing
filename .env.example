# Karaoke application — environment configuration
# Usage: cp .env.example .env && edit .env
#
# Required for BOTH modes (gpu and api):
#   OPENAI_API_KEY, GENIUS_TOKEN
#
# Additionally required for API mode:
#   MVSEP_API_KEY
#
# Prerequisites:
#   GPU mode: Docker, nvidia-container-toolkit, NVIDIA GPU
#   API mode: Docker

# --- General ---
ADMIN_SECRET=change-me-in-production
LOG_LEVEL=INFO
APP_PORT=80

# --- Required: LyricsSearcher keys (both modes) ---
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
GENIUS_TOKEN=...

# --- Required for API mode only ---
MVSEP_API_KEY=...

# --- Optional: GPU mode tuning ---
# WORKER_REPLICAS=1
# UVR_MODEL_NAME=model_bs_roformer_ep_317_sdr_12.9755.ckpt
# WHISPER_MODEL_SIZE=tiny

# --- Optional: API mode tuning ---
# LYRIC_EMBEDDER_BACKEND=local
