# Karaoke application — environment configuration
# Usage: cp .env.example .env && edit .env
#
# Prerequisites: Docker, nvidia-container-toolkit, NVIDIA GPU

# --- General ---
ADMIN_SECRET=change-me-in-production
LOG_LEVEL=INFO
APP_PORT=80

# --- Required: Lyrics agent ---
DEEPSEEK_API_KEY=...
YANDEX_SEARCH_API_KEY=...
YANDEX_SEARCH_FOLDER_ID=...

# --- Infrastructure credentials (have defaults, change for production) ---
# PG_PASSWORD=karaoke
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# RMQ_USER=karaoke
# RMQ_PASS=karaoke

# --- S3 presigned URLs (base URL visible to the browser) ---
S3_PRESIGNED_URL_BASE=http://localhost:9000

# --- Optional: Genius lyrics provider (text search, disabled by default) ---
# GENIUS_TOKEN=

# --- Optional tuning ---
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-proj-...
# WORKER_REPLICAS=1
# Override worker identity. By default entrypoint.sh auto-derives WORKER_ID
# from the container name (e.g. mouth-singing-worker-1) via the mounted
# docker.sock — stable per replica across `compose down/up`. Set this only
# to override that name (e.g. for a single-host non-Docker deploy).
# WORKER_ID=karaoke-worker-1
# UVR_MODEL_NAME=model_bs_roformer_ep_317_sdr_12.9755.ckpt
# WHISPER_MODEL_SIZE=medium
# VAD_TOP_DB=17

# --- Optional: per-step pipeline timeouts (proportional to mp3 duration) ---
# Base values are for a 180s reference mp3; actual timeout = base * (duration / 180).
# Empirical for MVP; raise if jobs frequently time out on slow GPUs.
# STEP_TIMEOUT_SEPARATING_BASE=30
# STEP_TIMEOUT_BACK_VOCAL_SEPARATING_BASE=30
# STEP_TIMEOUT_TRANSCRIBING_BASE=30
# STEP_TIMEOUT_ALIGNING_BASE=10
# STEP_TIMEOUT_BASELINE_SECONDS=180

# --- Optional: Back-vocal separator (Mel-Band RoFormer, lead vs backing) ---
# Runs after UVR, feeds lead-only vocals into MMS forced alignment.
# Whisper/VAD/lyrics search still use the FULL vocals (Whisper needs
# backing repeats/ad-libs for better recognition).
# BACK_VOCAL_ENABLED=true
# BACK_VOCAL_MODEL_NAME=mel_band_roformer_karaoke_aufr33_viperx_sdr_10.1956.ckpt
# BACK_VOCAL_CHUNK_BATCH_SIZE=2
# BACK_VOCAL_USE_AUTOCAST=true
# BACK_VOCAL_OVERLAP=4.0

# --- Optional: MMS pre-trim via Silero VAD ---
# Skips intro ad-libs/inhales before MMS forced alignment so the first
# word isn't anchored to low-confidence noise. Higher threshold = more
# conservative (keeps only confident speech onsets).
# MMS_PRE_TRIM_ENABLED=true
# MMS_PRE_TRIM_THRESHOLD=0.7
# MMS_PRE_TRIM_MIN_SPEECH_MS=300
# MMS_PRE_TRIM_LEAD_IN_MS=100

# --- Optional: MMS per-line RMS-dip adjustment ---
# For every first-in-line word, search the natural window
# [prev_word_end, this_word_end] for a sandwich'ed RMS dip (local
# minimum bordered by louder peaks on both sides) and shift the word's
# start to the end of that dip. Fixes MMS anchoring to ad-libs/backing.
# MMS_LINE_START_RMS_ADJUST=true

# --- Optional: MMS word-end drift adjustment ---
# Detects last phoneme spans that MMS stretched into silence/instrumental
# (emission drift). Structural filter (duration outlier vs track median)
# picks candidates; RMS back-track inside the span validates and trims
# only when audio is truly silent — legitimate sustained vocals stay.
# MMS_WORD_END_DRIFT_ADJUST=true

# --- Optional: MMS word-end sustain extension ---
# Opposite failure mode of drift. CTC emission fires once per phoneme
# at attack, so a sustained final vowel (typical at line-end) closes
# the word at its attack frame and the end is cut short. Forward RMS
# walk from the original end extends the word while audio stays voiced,
# capped by the next word's onset (or track end).
# MMS_WORD_END_SUSTAIN_EXTEND=true
