# Karaoke application environment configuration
# Copy to .env and fill in values

# --- General ---
ADMIN_SECRET=your-secret-here
LOG_LEVEL=INFO
APP_PORT=80

# --- Worker mode (gpu or api) ---
# WORKER_MODE=gpu

# --- Worker polling ---
# WORKER_POLL_INTERVAL=2

# --- Normalization stats ---
# NORMALIZATION_STATS_PATH=/data/models/feature_normalization_stats.json

# --- GPU mode settings ---
# UVR_MODEL_NAME=model_bs_roformer_ep_317_sdr_12.9755.ckpt
# WHISPER_MODEL_SIZE=tiny

# --- API mode settings ---
# MVSEP_API_KEY=your-mvsep-key
# LYRIC_EMBEDDER_BACKEND=local

# --- Shared API keys (both modes use for LyricsSearcher) ---
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o-mini
GENIUS_TOKEN=your-genius-token
