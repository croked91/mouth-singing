# ──────────────────────────────────────────────────────────────────────────────
# Karaoke App — Environment Variables
# Copy to .env and fill in required values: cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# Admin PIN for terminating sessions (sent via X-Admin-Secret header)
ADMIN_SECRET=changeme

# ── Soniox API (required for audio transcription in worker) ──────────────────
# Get key at https://soniox.com
SONOIX_API_KEY=
SONOIX_API_URL=https://api.soniox.com

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Worker settings ──────────────────────────────────────────────────────────
# How often the worker polls for new jobs (seconds)
WORKER_POLL_INTERVAL=2
# Max concurrent jobs per worker
WORKER_MAX_CONCURRENT=1

# ── Application port ─────────────────────────────────────────────────────────
# Port on which the app is accessible (frontend nginx)
APP_PORT=80

# ── VPN / Proxy (optional) ──────────────────────────────────────────────────
# If running from Russia, the worker needs VPN/proxy to reach Soniox API
# Set these to route worker traffic through a proxy
# HTTP_PROXY=socks5://host.docker.internal:1080
# HTTPS_PROXY=socks5://host.docker.internal:1080
